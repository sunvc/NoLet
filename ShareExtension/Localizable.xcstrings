{
  "sourceLanguage": "en",
  "strings": {
    "iCloud 云图标": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud cloud icon"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 云图标"
          }
        }
      }
    },
    "iCloud 服务暂时不可用，请稍后再试": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud unavailable. Try again later."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 服务暂时不可用，请稍后再试"
          }
        }
      }
    },
    "iCloud 访问受限，可能由家长控制或 MDM 设备管理策略导致": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud restricted by parental controls or MDM."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud access is restricted, possibly due to parental controls or MDM device management policies."
          }
        }
      }
    },
    "iCloud 账户可用": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud Available"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 账户可用"
          }
        }
      }
    },
    "iCloud状态检查": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud Status"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud状态检查"
          }
        }
      }
    },
    "iCloud状态检查中...": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Checking iCloud..."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在检查iCloud状态..."
          }
        }
      }
    },
    "上传到云端": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Upload to Cloud"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Upload to cloud"
          }
        }
      }
    },
    "保存失败": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save Failed"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保存失败"
          }
        }
      }
    },
    "保存成功": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Saved"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保存成功"
          }
        }
      }
    },
    "剩余空间不足": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Insufficient storage space"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "剩余空间不足"
          }
        }
      }
    },
    "参数不全": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Missing parameters"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "参数不全"
          }
        }
      }
    },
    "取消": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "取消"
          }
        }
      }
    },
    "图标额度剩余": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Icon quota remaining"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "图标额度剩余"
          }
        }
      }
    },
    "图片Key": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Image Key"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "图片Key"
          }
        }
      }
    },
    "图片key重复，请提供新图片以覆盖": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Key exists. Upload new to overwrite."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "图片key重复，请提供新图片以覆盖"
          }
        }
      }
    },
    "复制": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "复制"
          }
        }
      }
    },
    "提示": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Prompt"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "提示"
          }
        }
      }
    },
    "无法确定 iCloud 账户状态，可能是网络问题": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Can't check iCloud status. Verify network."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法确定 iCloud 账户状态，可能是网络问题"
          }
        }
      }
    },
    "未登录 iCloud，请登录 iCloud 账户": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in to iCloud"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未登录 iCloud，请登录 iCloud 账户"
          }
        }
      }
    },
    "未知 iCloud 状态": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unknown"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未知 iCloud 状态"
          }
        }
      }
    },
    "检查 iCloud 账户状态出错": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud Check Error"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检查 iCloud 账户状态出错"
          }
        }
      }
    },
    "正在处理中...": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Processing..."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在处理中..."
          }
        }
      }
    },
    "没有图片": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No Image"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有图片"
          }
        }
      }
    },
    "没有文件": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No Files"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有文件"
          }
        }
      }
    },
    "输入图片名称": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Image name"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "输入图片名称"
          }
        }
      }
    },
    "静音分组1小时": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mute 1h"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "静音分组1小时"
          }
