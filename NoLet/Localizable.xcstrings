{
  "sourceLanguage" : "en",
  "strings" : {
    "‼️参数可单独使用\n* /内容 或者 /标题/内容\n* group: 分组名，不传显示 `默认`\n* badge： 自定义角标 可选值 -1...\n* ttl: 消息保存时间 可选值 0..." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⚠️ Parameters can be used individually\n* /content or /title/content\n* group: group name, not passing shows `default`\n* badge: custom corner badge optional value -1...\n* ttl: message retention time optional value 0..."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "‼️参数可单独使用\n* /内容 或者 /标题/内容\n* group: 分组名，不传显示 `默认`\n* badge： 自定义角标 可选值 -1...\n* ttl: 消息保存时间 可选值 0..."
          }
        }
      }
    },
    "(必选)" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "(Required)"
