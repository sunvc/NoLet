{
  "sourceLanguage": "en",
  "strings": {
    "iCloud 服务暂时不可用，请稍后再试": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud unavailable. Try again later."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 服务暂时不可用，请稍后再试"
          }
        }
      }
    },
    "iCloud 访问受限，可能由家长控制或 MDM 设备管理策略导致": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud restricted by parental controls or MDM."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud access restricted, possibly due to parental controls or MDM device management policies."
          }
        }
      }
    },
    "iCloud 账户可用": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud Available"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 账户可用"
          }
        }
      }
    },
    "保存失败": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save Failed"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保存失败"
          }
