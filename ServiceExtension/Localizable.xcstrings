          "stringUnit": {
            "state": "translated",
            "value": "Saved"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保存成功"
          }
        }
      }
    },
    "参数不全": {
      "localizations": {
